# Tenderly Virtual Testnet Configuration
TENDERLY_RPC_URL=https://virtual.mainnet.rpc.tenderly.co/YOUR_RPC_ID
TENDERLY_CHAIN_ID=1

# Deployer Private Key (use a test wallet, never production keys)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Sepolia Testnet (optional fallback)
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# CRE Forwarder Address (get from CRE CLI logs or Tenderly simulation)
CRE_FORWARDER_ADDRESS=0x0000000000000000000000000000000000000000
